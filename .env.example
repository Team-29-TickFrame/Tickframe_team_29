# Use a long, randomly generated value. Never commit the real .env file.
POSTGRES_PASSWORD=replace-with-a-random-local-password

# Optional: override exchange endpoint fallbacks for networks where a domain is blocked.
# TICKFRAME_BINANCE_WS_URLS=wss://data-stream.binance.vision/stream,wss://stream.binance.com:9443/stream
# TICKFRAME_BYBIT_WS_URLS=wss://stream.bybit.com/v5/public/spot,wss://stream.bybit-tr.com/v5/public/spot,wss://stream.bybit.kz/v5/public/spot
# TICKFRAME_BINANCE_REST_URLS=https://data-api.binance.vision/api/v3/klines,https://api.binance.com/api/v3/klines
# TICKFRAME_BYBIT_REST_URLS=https://api.bybit.kz/v5/market/kline,https://api.bybit.com/v5/market/kline,https://api.bytick.com/v5/market/kline

# Optional: auto-recover missing 1m OHLCV after backend restart or reconnect.
# TICKFRAME_RECOVERY_BACKFILL_HOURS=72h
# TICKFRAME_RECOVERY_BACKFILL_HOURS=12d
# TICKFRAME_DISABLE_RECOVERY_BACKFILL=0

# Optional: auto-load official Binance 1s REST candles for recent seconds.
# Bybit Spot REST does not expose 1s klines, so Bybit second charts can use
# Binance 1s historical candles as an explicit proxy fallback.
# TICKFRAME_BINANCE_1S_BACKFILL_HOURS=24h

# Optional: repair already stored 1s candles from retained raw trades after
# backend startup/reconnect. Capped by raw_trade_retention_hours from config.
# TICKFRAME_SECOND_REPAIR_HOURS=72h

# Optional: delay short-timeframe chart candles so 1s/5s/15s windows are
# rebuilt from raw trades after late exchange messages have had time to arrive.
# Accepted examples: 2000, 2s, 1500ms.
TICKFRAME_STABLE_CHART_DELAY_MS=2000
